PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://erp_user:erp_pass@localhost:5432/erp_qween?schema=public"
JWT_SECRET="change-me"
JWT_EXPIRE="24h"
JWT_REFRESH_EXPIRE="7d"
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=150
DEFAULT_CURRENCY="SAR"
COMPANY_NAME="ERP Qween"
ZATCA_ENABLED=false
ZATCA_API_URL="https://gw-fatoora.zatca.gov.sa"
LOG_LEVEL=info
LOG_FILE_PATH="./logs"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4"
ASSISTANT_MAX_OUTPUT_TOKENS=450
