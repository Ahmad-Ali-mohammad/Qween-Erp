{
  "name": "erp-qween",
  "version": "1.0.0",
  "private": true,
  "description": "ERP On-Premise for single company",
  "main": "dist/server.js",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "tsx watch src/server.ts",
    "dev:portal": "npm run dev -w @erp-qween/control-center",
    "dev:legacy-web": "npm run dev -w erp-qween-web",
    "build": "npm run build:api",
    "build:api": "tsc -p tsconfig.json",
    "build:apps": "npm run build --workspaces --if-present",
    "build:all": "npm run build:api && npm run build:apps",
    "start": "node dist/server.js",
    "test": "jest --runInBand",
    "lint": "tsc --noEmit",
    "check:modular": "python .codex/skills/erp-qween-development/scripts/check_modular_guardrails.py",
    "check:encoding": "node scripts/check-encoding.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.42.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.16.9",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.17.2",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "typescript": "^5.6.2",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1"
  }
}
