generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalSource {
  MANUAL
  SALES
  PURCHASE
  PAYROLL
  ASSETS
  REVERSAL
}

enum JournalStatus {
  DRAFT
  PENDING
  POSTED
  VOID
  REVERSED
}

enum InvoiceType {
  SALES
  PURCHASE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIAL
  CANCELLED
}

enum PaymentType {
  RECEIPT
  PAYMENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
  BOUNCED
}

enum FiscalYearStatus {
  OPEN
  CLOSED
  ADJUSTING
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum AssetStatus {
  ACTIVE
  MAINTENANCE
  SOLD
  SCRAPPED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum BudgetControlLevel {
  NONE
  WARNING
  HARD
}

enum TaxType {
  VAT
  WHT
}

enum TaxDeclarationStatus {
  DRAFT
  FILED
  PAID
  CANCELLED
}

enum ApprovalLifecycleStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum PostingLifecycleStatus {
  UNPOSTED
  POSTED
  REVERSED
  NOT_APPLICABLE
}

enum DocumentProvider {
  LOCAL
  S3
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model CompanyProfile {
  id                      Int      @id @default(1)
  nameAr                  String
  nameEn                  String?
  commercialRegistration  String?
  taxNumber               String?
  vatNumber               String?
  address                 String?
  city                    String?
  phone                   String?
  email                   String?
  logo                    String?
  fiscalYearStartMonth    Int      @default(1)
  currency                String   @default("SAR")
  updatedAt               DateTime @updatedAt
}

model SystemSettings {
  id                 Int      @id @default(1)
  allowNegativeStock Boolean  @default(false)
  requireApproval    Boolean  @default(true)
  approvalThreshold  Decimal  @default(10000)
  invoicePrefix      String   @default("INV")
  quotePrefix        String   @default("QT")
  postingAccounts    Json     @default("{}")
  updatedAt          DateTime @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  nameAr      String
  description String?
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  users User[]
}

model User {
  id               Int      @id @default(autoincrement())
  username         String   @unique
  email            String   @unique
  password         String
  fullName         String
  phone            String?
  position         String?
  roleId           Int
  role             Role     @relation(fields: [roleId], references: [id])
  isActive         Boolean  @default(true)
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  lastLogin        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions         AuthSession[]
  journalsCreated  JournalEntry[] @relation("CreatedBy")
  journalsPosted   JournalEntry[] @relation("PostedBy")
  invoicesCreated  Invoice[]      @relation("InvoiceCreatedBy")
  paymentsCreated  Payment[]      @relation("PaymentCreatedBy")
  auditLogs        AuditLog[]
  documentsUploaded Document[]    @relation("DocumentUploadedBy")
  outboxEventsAuthored OutboxEvent[] @relation("OutboxEventActor")
  branchAccesses   UserBranchAccess[]
}

model Branch {
  id                Int      @id @default(autoincrement())
  code              String   @unique
  nameAr            String
  nameEn            String?
  city              String?
  address           String?
  phone             String?
  email             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  approvalWorkflows ApprovalWorkflow[]
  attendances       Attendance[]
  contracts         Contract[]
  customers         Customer[]
  documents         Document[]
  employees         Employee[]
  fixedAssets       FixedAsset[]
  invoices          Invoice[]
  outboxEvents      OutboxEvent[]
  payments          Payment[]
  printAudits       PrintAudit[]
  printJobs         PrintJob[]
  printTemplates    PrintTemplate[]
  exportJobs        ExportJob[]
  conversionJobs    ConversionJob[]
  payrollLines      PayrollLine[]
  payrollRuns       PayrollRun[]
  projects          Project[]
  purchaseOrders    PurchaseOrder[]
  purchaseReturns   PurchaseReturn[]
  salesQuotes       SalesQuote[]
  salesReturns      SalesReturn[]
  siteAttendances   SiteAttendance[]
  siteDailyLogs     SiteDailyLog[]
  siteIssues        SiteIssue[]
  siteMaterialRequests SiteMaterialRequest[]
  sitePhotos        SitePhoto[]
  siteProgressReports SiteProgress[]
  subcontracts      Subcontract[]
  suppliers         Supplier[]
  tenders           Tender[]
  timesheets        Timesheet[]
  userBranchAccesses UserBranchAccess[]
  warehouses        Warehouse[]
}

model ApprovalWorkflow {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  nameAr          String
  nameEn          String?
  entityType      String
  branchId        Int?
  branch          Branch?  @relation(fields: [branchId], references: [id])
  thresholdAmount Decimal?
  isActive        Boolean  @default(true)
  steps           Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([entityType])
  @@index([branchId])
}

model Document {
  id            Int              @id @default(autoincrement())
  module        String
  entityType    String
  entityId      String
  branchId      Int?
  branch        Branch?          @relation(fields: [branchId], references: [id])
  status        DocumentStatus   @default(ACTIVE)
  provider      DocumentProvider @default(LOCAL)
  fileName      String
  originalName  String?
  mimeType      String
  sizeBytes     Int              @default(0)
  bucket        String?
  storageKey    String
  checksum      String?
  ocrText       String?
  metadata      Json             @default("{}")
  versionNumber Int              @default(1)
  uploadedById  Int?
  uploadedBy    User?            @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([module, entityType, entityId])
  @@index([branchId])
  @@unique([storageKey, versionNumber])
}

model OutboxEvent {
  id            Int          @id @default(autoincrement())
  eventId       String       @unique @default(uuid())
  eventType     String
  aggregateType String
  aggregateId   String
  occurredAt    DateTime     @default(now())
  actorId       Int?
  actor         User?        @relation("OutboxEventActor", fields: [actorId], references: [id])
  branchId      Int?
  branch        Branch?      @relation(fields: [branchId], references: [id])
  correlationId String?
  version       Int          @default(1)
  payload       Json
  status        OutboxStatus @default(PENDING)
  retryCount    Int          @default(0)
  lastError     String?
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  consumptions EventConsumption[]

  @@index([status, createdAt])
  @@index([aggregateType, aggregateId])
  @@index([branchId])
}

model EventConsumption {
  id            Int         @id @default(autoincrement())
  consumerName  String
  eventId       String
  outboxEventId Int?
  outboxEvent   OutboxEvent? @relation(fields: [outboxEventId], references: [id], onDelete: SetNull)
  status        String      @default("CONSUMED")
  result        Json?
  errorMessage  String?
  consumedAt    DateTime    @default(now())

  @@unique([consumerName, eventId])
  @@index([outboxEventId])
}

model AuthSession {
  id           Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken  String   @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Account {
  id            Int         @id @default(autoincrement())
  code          String      @unique
  nameAr        String
  nameEn        String?
  type          AccountType
  subType       String?
  parentId      Int?
  parent        Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]   @relation("AccountHierarchy")
  level         Int         @default(1)
  isControl     Boolean     @default(false)
  allowPosting  Boolean     @default(true)
  normalBalance String      @default("Debit")
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  journalLines  JournalLine[]
  balances      AccountBalance[]
  budgetLines   BudgetLine[]
  bankAccounts  BankAccount[] @relation("BankGLAccount")
}

model AccountBalance {
  id             Int      @id @default(autoincrement())
  accountId      Int
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fiscalYear     Int
  period         Int
  openingBalance Decimal  @default(0)
  debit          Decimal  @default(0)
  credit         Decimal  @default(0)
  closingBalance Decimal  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([accountId, fiscalYear, period])
  @@index([fiscalYear, period])
}

model FiscalYear {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  startDate DateTime
  endDate   DateTime
  status    FiscalYearStatus @default(OPEN)
  isCurrent Boolean          @default(false)
  createdAt DateTime         @default(now())

  periods AccountingPeriod[]
}

model AccountingPeriod {
  id           Int         @id @default(autoincrement())
  fiscalYearId Int
  fiscalYear   FiscalYear  @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  number       Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       PeriodStatus @default(OPEN)
  canPost      Boolean      @default(true)
  closedAt     DateTime?
  closedBy     Int?

  journalEntries JournalEntry[]

  @@unique([fiscalYearId, number])
  @@index([startDate, endDate])
}

model JournalEntry {
  id              Int           @id @default(autoincrement())
  entryNumber     String        @unique
  date            DateTime
  periodId        Int?
  period          AccountingPeriod? @relation(fields: [periodId], references: [id])
  description     String?
  reference       String?
  source          JournalSource @default(MANUAL)
  status          JournalStatus @default(DRAFT)
  totalDebit      Decimal       @default(0)
  totalCredit     Decimal       @default(0)
  attachmentCount Int           @default(0)
  notes           String?
  createdById     Int
  createdBy       User          @relation("CreatedBy", fields: [createdById], references: [id])
  postedById      Int?
  postedBy        User?         @relation("PostedBy", fields: [postedById], references: [id])
  postedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lines             JournalLine[]
  invoiceLinks      Invoice[] @relation("InvoiceJournalEntry")
  paymentLinks      Payment[] @relation("PaymentJournalEntry")
  bankTxnLinks      BankTransaction[] @relation("BankTxnJournalEntry")
  depreciationLinks DepreciationSchedule[] @relation("DepScheduleJournalEntry")

  @@index([date, status])
  @@index([createdAt])
}

model JournalLine {
  id            Int      @id @default(autoincrement())
  entryId        Int
  entry          JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNumber     Int
  accountId      Int
  account        Account  @relation(fields: [accountId], references: [id])
  description    String?
  debit          Decimal  @default(0)
  credit         Decimal  @default(0)
  projectId      Int?
  project        Project? @relation(fields: [projectId], references: [id])
  departmentId   Int?
  department     Department? @relation(fields: [departmentId], references: [id])
  costCenterId   Int?
  costCenter     CostCenter? @relation(fields: [costCenterId], references: [id])
  employeeId     Int?
  isCleared      Boolean  @default(false)
  clearedAt      DateTime?
  createdAt      DateTime @default(now())

  @@unique([entryId, lineNumber])
  @@index([accountId])
}

model Project {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  nameAr      String
  nameEn      String?
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  contractId  Int?
  contract    Contract? @relation(fields: [contractId], references: [id])
  type        String?
  status      String   @default("Active")
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?
  actualCost  Decimal  @default(0)
  attachmentsCount Int @default(0)
  managerId   Int?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalLines JournalLine[]
  invoices     Invoice[]
  projectExpenses ProjectExpense[]
  projectTasks    ProjectTask[]
  siteAttendances SiteAttendance[]
  siteDailyLogs   SiteDailyLog[]
  siteIssues      SiteIssue[]
  siteMaterialRequests SiteMaterialRequest[]
  sitePhotos      SitePhoto[]
  siteProgressReports SiteProgress[]
  subcontracts    Subcontract[]
  timesheets      Timesheet[]

  @@index([branchId])
  @@index([contractId])
}

model Department {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  nameAr      String
  nameEn      String?
  parentId    Int?
  parent      Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DeptHierarchy")
  managerId   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  journalLines JournalLine[]
}

model CostCenter {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  nameAr      String
  nameEn      String?
  budget      Decimal?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  journalLines JournalLine[]
}

model Customer {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  nameAr         String
  nameEn         String?
  branchId       Int?
  branch         Branch?  @relation(fields: [branchId], references: [id])
  type           String   @default("Company")
  nationalId     String?
  taxNumber      String?
  vatNumber      String?
  address        String?
  city           String?
  phone          String?
  mobile         String?
  email          String?
  creditLimit    Decimal  @default(0)
  currentBalance Decimal  @default(0)
  paymentTerms   Int      @default(30)
  attachmentsCount Int    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices Invoice[]
  payments Payment[]
  contacts Contact[]
  tenders  Tender[]

  @@index([branchId])
}

model Supplier {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  nameAr         String
  nameEn         String?
  branchId       Int?
  branch         Branch?  @relation(fields: [branchId], references: [id])
  type           String   @default("Local")
  nationalId     String?
  taxNumber      String?
  vatNumber      String?
  address        String?
  city           String?
  phone          String?
  mobile         String?
  email          String?
  creditLimit    Decimal  @default(0)
  currentBalance Decimal  @default(0)
  paymentTerms   Int      @default(30)
  bankName       String?
  bankAccount    String?
  iban           String?
  attachmentsCount Int    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices Invoice[]
  payments Payment[]
  contacts Contact[]
  subcontracts Subcontract[]

  @@index([branchId])
}

model Contact {
  id         Int      @id @default(autoincrement())
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String
  position   String?
  phone      String?
  mobile     String?
  email      String?
  isPrimary  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([supplierId])
}

model Invoice {
  id               Int          @id @default(autoincrement())
  number           String       @unique
  type             InvoiceType
  date             DateTime
  dueDate          DateTime?
  branchId         Int?
  branch           Branch?      @relation(fields: [branchId], references: [id])
  customerId       Int?
  customer         Customer?    @relation(fields: [customerId], references: [id])
  supplierId       Int?
  supplier         Supplier?    @relation(fields: [supplierId], references: [id])
  subtotal         Decimal      @default(0)
  discount         Decimal      @default(0)
  taxableAmount    Decimal      @default(0)
  vatRate          Decimal      @default(15)
  vatAmount        Decimal      @default(0)
  withholdingTax   Decimal      @default(0)
  total            Decimal      @default(0)
  paidAmount       Decimal      @default(0)
  outstanding      Decimal      @default(0)
  status           InvoiceStatus @default(DRAFT)
  paymentStatus    String       @default("PENDING")
  approvalStatus   ApprovalLifecycleStatus @default(DRAFT)
  postingStatus    PostingLifecycleStatus  @default(UNPOSTED)
  projectId        Int?
  project          Project?     @relation(fields: [projectId], references: [id])
  notes            String?
  internalNotes    String?
  attachmentsCount Int          @default(0)
  zatcaUuid        String?
  zatcaHash        String?
  zatcaQr          String?
  isZatcaCompliant Boolean      @default(false)
  createdById      Int?
  createdBy        User?        @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  journalEntryId   Int?
  journalEntry     JournalEntry? @relation("InvoiceJournalEntry", fields: [journalEntryId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  lines    InvoiceLine[]
  payments PaymentAllocation[]
  subcontractIpcs SubcontractIpc[] @relation("SubcontractIpcPayableInvoice")

  @@index([date, status])
  @@index([createdAt])
  @@index([branchId])
}

model InvoiceLine {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineNumber  Int
  itemId      Int?
  description String
  quantity    Decimal  @default(1)
  unitPrice   Decimal
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(15)
  taxAmount   Decimal  @default(0)
  total       Decimal
  accountId   Int?
  createdAt   DateTime @default(now())

  @@unique([invoiceId, lineNumber])
}

model BankAccount {
  id             Int      @id @default(autoincrement())
  name           String
  accountNumber  String   @unique
  iban           String?
  bankName       String
  currency       String   @default("SAR")
  accountType    String   @default("Current")
  openingBalance Decimal  @default(0)
  currentBalance Decimal  @default(0)
  glAccountId    Int?
  glAccount      Account? @relation("BankGLAccount", fields: [glAccountId], references: [id])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions BankTransaction[]
  payments     Payment[]
}

model BankTransaction {
  id            Int      @id @default(autoincrement())
  bankId        Int
  bank          BankAccount @relation(fields: [bankId], references: [id], onDelete: Cascade)
  date          DateTime
  valueDate     DateTime?
  reference     String?
  description   String
  debit         Decimal  @default(0)
  credit        Decimal  @default(0)
  balance       Decimal?
  type          String?
  counterparty  String?
  isReconciled  Boolean  @default(false)
  reconciledAt  DateTime?
  journalEntryId Int?
  journalEntry  JournalEntry? @relation("BankTxnJournalEntry", fields: [journalEntryId], references: [id])
  createdAt     DateTime @default(now())

  @@index([date])
}

model Payment {
  id            Int          @id @default(autoincrement())
  number        String       @unique
  date          DateTime
  type          PaymentType
  method        PaymentMethod
  amount        Decimal
  branchId      Int?
  branch        Branch?      @relation(fields: [branchId], references: [id])
  currency      String       @default("SAR")
  bankId        Int?
  bank          BankAccount? @relation(fields: [bankId], references: [id])
  customerId    Int?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  supplierId    Int?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  checkNumber   String?
  checkDate     DateTime?
  checkBank     String?
  status        PaymentStatus @default(PENDING)
  approvalStatus ApprovalLifecycleStatus @default(PENDING)
  postingStatus  PostingLifecycleStatus  @default(UNPOSTED)
  description   String?
  notes         String?
  attachmentsCount Int       @default(0)
  journalEntryId Int?
  journalEntry   JournalEntry? @relation("PaymentJournalEntry", fields: [journalEntryId], references: [id])
  createdById   Int?
  createdBy     User?        @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  allocations PaymentAllocation[]

  @@index([date, status])
  @@index([createdAt])
  @@index([branchId])
}

model PaymentAllocation {
  id        Int      @id @default(autoincrement())
  paymentId Int
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal
  createdAt DateTime @default(now())

  @@unique([paymentId, invoiceId])
}

model AssetCategory {
  id                 Int      @id @default(autoincrement())
  code               String   @unique
  nameAr             String
  nameEn             String?
  depreciationMethod String   @default("StraightLine")
  usefulLifeMonths   Int
  salvagePercent     Decimal  @default(0)
  glAssetId          Int?
  glAccumulatedId    Int?
  glExpenseId        Int?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  assets FixedAsset[]
}

model FixedAsset {
  id                     Int        @id @default(autoincrement())
  code                   String     @unique
  nameAr                 String
  nameEn                 String?
  branchId               Int?
  branch                 Branch?    @relation(fields: [branchId], references: [id])
  categoryId             Int
  category               AssetCategory @relation(fields: [categoryId], references: [id])
  serialNumber           String?
  model                  String?
  manufacturer           String?
  purchaseDate           DateTime?
  purchaseCost           Decimal
  supplierId             Int?
  usefulLifeMonths       Int?
  depreciationMethod     String?
  salvageValue           Decimal    @default(0)
  depreciationStart      DateTime?
  accumulatedDepreciation Decimal   @default(0)
  netBookValue           Decimal
  attachmentsCount       Int        @default(0)
  location               String?
  departmentId           Int?
  custodianId            Int?
  status                 AssetStatus @default(ACTIVE)
  isDepreciating         Boolean    @default(true)
  lastDepreciationDate   DateTime?
  notes                  String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  depreciationSchedule DepreciationSchedule[]

  @@index([branchId])
}

model DepreciationSchedule {
  id            Int      @id @default(autoincrement())
  assetId       Int
  asset         FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fiscalYear    Int
  period        Int
  openingNBV    Decimal  @default(0)
  expense       Decimal  @default(0)
  accumulated   Decimal  @default(0)
  closingNBV    Decimal  @default(0)
  journalEntryId Int?
  journalEntry  JournalEntry? @relation("DepScheduleJournalEntry", fields: [journalEntryId], references: [id])
  status        String   @default("Pending")
  postedAt      DateTime?
  createdAt     DateTime @default(now())

  @@unique([assetId, fiscalYear, period])
}

model Budget {
  id           Int                @id @default(autoincrement())
  code         String             @unique
  nameAr       String
  nameEn       String?
  fiscalYear   Int
  version      String             @default("Original")
  status       BudgetStatus       @default(DRAFT)
  controlLevel BudgetControlLevel @default(NONE)
  totalAmount  Decimal            @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  lines BudgetLine[]
}

model BudgetLine {
  id        Int      @id @default(autoincrement())
  budgetId  Int
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id])
  period    Int
  amount    Decimal
  actual    Decimal  @default(0)
  committed Decimal  @default(0)
  variance  Decimal  @default(0)
