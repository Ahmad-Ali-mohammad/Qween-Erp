generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalSource {
  MANUAL
  SALES
  PURCHASE
  PAYROLL
  ASSETS
  REVERSAL
}

enum JournalStatus {
  DRAFT
  PENDING
  POSTED
  VOID
  REVERSED
}

enum InvoiceType {
  SALES
  PURCHASE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIAL
  CANCELLED
}

enum PaymentType {
  RECEIPT
  PAYMENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
  BOUNCED
}

enum FiscalYearStatus {
  OPEN
  CLOSED
  ADJUSTING
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum AssetStatus {
  ACTIVE
  MAINTENANCE
  SOLD
  SCRAPPED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum BudgetControlLevel {
  NONE
  WARNING
  HARD
}

enum TaxType {
  VAT
  WHT
}

enum TaxDeclarationStatus {
  DRAFT
  FILED
  PAID
  CANCELLED
}

enum SequenceResetPolicy {
  NEVER
  YEARLY
  MONTHLY
}

enum WorkflowInstanceStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

model CompanyProfile {
  id                      Int      @id @default(1)
  nameAr                  String
  nameEn                  String?
  commercialRegistration  String?
  taxNumber               String?
  vatNumber               String?
  address                 String?
  city                    String?
  phone                   String?
  email                   String?
  logo                    String?
  fiscalYearStartMonth    Int      @default(1)
  currency                String   @default("KWD")
  timezone                String   @default("Asia/Kuwait")
  locale                  String   @default("ar-KW")
  baseCountry             String   @default("KW")
  updatedAt               DateTime @updatedAt
}

model SystemSettings {
  id                 Int      @id @default(1)
  allowNegativeStock Boolean  @default(false)
  requireApproval    Boolean  @default(true)
  approvalThreshold  Decimal  @default(10000)
  invoicePrefix      String   @default("INV")
  quotePrefix        String   @default("QT")
  postingAccounts    Json     @default("{}")
  updatedAt          DateTime @updatedAt
}

model Branch {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  nameAr          String
  nameEn          String?
  timezone        String   @default("Asia/Kuwait")
  currencyCode    String   @default("KWD")
  numberingPrefix String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  defaultUsers         User[]              @relation("UserDefaultBranch")
  sites                Site[]
  userBranchAccesses   UserBranchAccess[]
  userProjectAccesses  UserProjectAccess[]
  numberSequences      NumberSequence[]
  departments          Department[]
  warehouses           Warehouse[]
  stockMovements       StockMovement[]
  stockCounts          StockCount[]
  purchaseRequests     PurchaseRequest[]
  purchaseOrders       PurchaseOrder[]
  purchaseReceipts     PurchaseReceipt[]
  bankAccounts         BankAccount[]
  payments             Payment[]
  journalEntries       JournalEntry[]
  journalLines         JournalLine[]
  projects             Project[]
  employees            Employee[]
  contracts            Contract[]
  equipmentAllocations EquipmentAllocation[]
  maintenanceLogs      MaintenanceLog[]
  attendances          Attendance[]
  timesheets           Timesheet[]
  payrollRuns          PayrollRun[]
  payrollLines         PayrollLine[]
  documentTemplates    DocumentTemplate[]
  subcontractContracts SubcontractContract[]
  subcontractCertificates SubcontractCertificate[]
  subcontractChangeOrders SubcontractChangeOrder[]
  subcontractPayments  SubcontractPayment[]
  siteDailyLogs        SiteDailyLog[]
  siteMaterialRequests SiteMaterialRequest[]
  siteProgressEntries  SiteProgressEntry[]
  siteEquipmentIssues  SiteEquipmentIssue[]

  @@index([isActive])
}

model Site {
  id         Int      @id @default(autoincrement())
  branchId   Int
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code       String
  nameAr     String
  nameEn     String?
  location   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  warehouses Warehouse[]
  projects   Project[]
  dailyLogs  SiteDailyLog[]
  materialRequests SiteMaterialRequest[]
  progressEntries SiteProgressEntry[]
  equipmentIssues SiteEquipmentIssue[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  nameAr      String
  description String?
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  users User[]
}

model User {
  id               Int      @id @default(autoincrement())
  username         String   @unique
  email            String   @unique
  password         String
  fullName         String
  phone            String?
  position         String?
  roleId           Int
  role             Role     @relation(fields: [roleId], references: [id])
  defaultBranchId  Int?
  defaultBranch    Branch?  @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id], onDelete: SetNull)
  isActive         Boolean  @default(true)
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  lastLogin        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions         AuthSession[]
  journalsCreated  JournalEntry[] @relation("CreatedBy")
  journalsPosted   JournalEntry[] @relation("PostedBy")
  invoicesCreated  Invoice[]      @relation("InvoiceCreatedBy")
  paymentsCreated  Payment[]      @relation("PaymentCreatedBy")
  auditLogs        AuditLog[]
  branchAccesses   UserBranchAccess[]
  projectAccesses  UserProjectAccess[]
  warehouseAccesses UserWarehouseAccess[]
  printJobs        PrintJob[]
}

model AuthSession {
  id           Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken  String   @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
}

model UserBranchAccess {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId   Int
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  canRead    Boolean  @default(true)
  canWrite   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, branchId])
  @@index([branchId])
}

model UserProjectAccess {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  Int
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  canRead    Boolean  @default(true)
  canWrite   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, projectId])
  @@index([branchId])
}

model UserWarehouseAccess {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouseId Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  canRead     Boolean  @default(true)
  canWrite    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, warehouseId])
}

model Account {
  id            Int         @id @default(autoincrement())
  code          String      @unique
  nameAr        String
  nameEn        String?
  type          AccountType
  subType       String?
  parentId      Int?
  parent        Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]   @relation("AccountHierarchy")
  level         Int         @default(1)
  isControl     Boolean     @default(false)
  allowPosting  Boolean     @default(true)
  normalBalance String      @default("Debit")
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  journalLines  JournalLine[]
  balances      AccountBalance[]
  budgetLines   BudgetLine[]
  bankAccounts  BankAccount[] @relation("BankGLAccount")
}

model AccountBalance {
  id             Int      @id @default(autoincrement())
  accountId      Int
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fiscalYear     Int
  period         Int
  openingBalance Decimal  @default(0)
  debit          Decimal  @default(0)
  credit         Decimal  @default(0)
  closingBalance Decimal  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([accountId, fiscalYear, period])
  @@index([fiscalYear, period])
}

model FiscalYear {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  startDate DateTime
  endDate   DateTime
  status    FiscalYearStatus @default(OPEN)
  isCurrent Boolean          @default(false)
  createdAt DateTime         @default(now())

  periods AccountingPeriod[]
}

model AccountingPeriod {
  id           Int         @id @default(autoincrement())
  fiscalYearId Int
  fiscalYear   FiscalYear  @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  number       Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       PeriodStatus @default(OPEN)
  canPost      Boolean      @default(true)
  closedAt     DateTime?
  closedBy     Int?

  journalEntries JournalEntry[]

  @@unique([fiscalYearId, number])
  @@index([startDate, endDate])
}

model JournalEntry {
  id              Int           @id @default(autoincrement())
  entryNumber     String        @unique
  date            DateTime
  branchId        Int?
  branch          Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  periodId        Int?
  period          AccountingPeriod? @relation(fields: [periodId], references: [id])
  description     String?
  reference       String?
  source          JournalSource @default(MANUAL)
  status          JournalStatus @default(DRAFT)
  totalDebit      Decimal       @default(0)
  totalCredit     Decimal       @default(0)
  attachmentCount Int           @default(0)
  notes           String?
  createdById     Int
  createdBy       User          @relation("CreatedBy", fields: [createdById], references: [id])
  postedById      Int?
  postedBy        User?         @relation("PostedBy", fields: [postedById], references: [id])
  postedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lines             JournalLine[]
  invoiceLinks      Invoice[] @relation("InvoiceJournalEntry")
  paymentLinks      Payment[] @relation("PaymentJournalEntry")
  bankTxnLinks      BankTransaction[] @relation("BankTxnJournalEntry")
  depreciationLinks DepreciationSchedule[] @relation("DepScheduleJournalEntry")

  @@index([date, status])
  @@index([createdAt])
  @@index([branchId, date])
}

model JournalLine {
  id            Int      @id @default(autoincrement())
  entryId        Int
  entry          JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNumber     Int
  accountId      Int
  account        Account  @relation(fields: [accountId], references: [id])
  description    String?
  debit          Decimal  @default(0)
  credit         Decimal  @default(0)
  branchId       Int?
  branch         Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  projectId      Int?
  project        Project? @relation(fields: [projectId], references: [id])
  departmentId   Int?
  department     Department? @relation(fields: [departmentId], references: [id])
  costCenterId   Int?
  costCenter     CostCenter? @relation(fields: [costCenterId], references: [id])
  contractId     Int?
  contract       Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  employeeId     Int?
  isCleared      Boolean  @default(false)
  clearedAt      DateTime?
  createdAt      DateTime @default(now())

  @@unique([entryId, lineNumber])
  @@index([accountId])
  @@index([branchId, createdAt])
  @@index([projectId, createdAt])
}

model Project {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  nameAr      String
  nameEn      String?
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  siteId      Int?
  site        Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  contractId  Int?
  contract    Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  type        String?
  status      String   @default("Active")
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?
  actualCost  Decimal  @default(0)
  managerId   Int?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalLines     JournalLine[]
  invoices         Invoice[]
  phases           ProjectPhase[]
  budgets          ProjectBudget[]
  changeOrders     ChangeOrder[]
  tasks            ProjectTask[]
  expenses         ProjectExpense[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]
  stockMovements   StockMovement[]
  userAccesses     UserProjectAccess[]
  equipmentAllocations EquipmentAllocation[]
  maintenanceLogs  MaintenanceLog[]
  timesheets       Timesheet[]
  subcontractContracts SubcontractContract[]
  subcontractCertificates SubcontractCertificate[]
  subcontractChangeOrders SubcontractChangeOrder[]
  subcontractPayments SubcontractPayment[]
  siteDailyLogs    SiteDailyLog[]
  siteMaterialRequests SiteMaterialRequest[]
  siteProgressEntries SiteProgressEntry[]
  siteEquipmentIssues SiteEquipmentIssue[]

  @@index([branchId, status])
  @@index([contractId])
}

model ProjectPhase {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String?
  nameAr      String
  nameEn      String?
  status      String   @default("PLANNED")
  sequence    Int      @default(1)
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal  @default(0)
  actualCost  Decimal  @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks        ProjectTask[]
  budgets      ProjectBudget[]
  changeOrders ChangeOrder[]
  expenses     ProjectExpense[]
  siteProgressEntries SiteProgressEntry[]

  @@index([projectId, sequence])
  @@index([status])
}

model ProjectBudget {
  id              Int      @id @default(autoincrement())
  projectId       Int
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseId         Int?
  phase           ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  category        String
  baselineAmount  Decimal  @default(0)
  approvedAmount  Decimal  @default(0)
  committedAmount Decimal  @default(0)
  actualAmount    Decimal  @default(0)
  currencyCode    String   @default("KWD")
  status          String   @default("ACTIVE")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId, phaseId])
  @@index([category])
}

model ChangeOrder {
  id            Int      @id @default(autoincrement())
  projectId     Int
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseId       Int?
  phase         ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  number        String   @unique
  title         String
  description   String?
  amount        Decimal  @default(0)
  impactDays    Int      @default(0)
  status        String   @default("DRAFT")
  requestedDate DateTime @default(now())
  approvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId, status])
}

model Department {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  nameAr      String
  nameEn      String?
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  parentId    Int?
  parent      Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DeptHierarchy")
  managerId   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  journalLines JournalLine[]

  @@index([branchId, isActive])
}

model CostCenter {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  nameAr      String
  nameEn      String?
  budget      Decimal?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  journalLines JournalLine[]
}

model Customer {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  nameAr         String
  nameEn         String?
  type           String   @default("Company")
  nationalId     String?
  taxNumber      String?
  vatNumber      String?
  address        String?
  city           String?
  phone          String?
  mobile         String?
  email          String?
  creditLimit    Decimal  @default(0)
  currentBalance Decimal  @default(0)
  paymentTerms   Int      @default(30)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices Invoice[]
  payments Payment[]
  contacts Contact[]
}

model Supplier {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  nameAr         String
  nameEn         String?
  type           String   @default("Local")
  nationalId     String?
  taxNumber      String?
  vatNumber      String?
  address        String?
  city           String?
  phone          String?
  mobile         String?
  email          String?
  creditLimit    Decimal  @default(0)
  currentBalance Decimal  @default(0)
  paymentTerms   Int      @default(30)
  bankName       String?
  bankAccount    String?
  iban           String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices Invoice[]
  payments Payment[]
  contacts Contact[]
  maintenanceLogs MaintenanceLog[]
}

model Contact {
  id         Int      @id @default(autoincrement())
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String
  position   String?
  phone      String?
  mobile     String?
  email      String?
  isPrimary  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([supplierId])
}

model Invoice {
  id               Int          @id @default(autoincrement())
  number           String       @unique
  type             InvoiceType
  date             DateTime
  dueDate          DateTime?
  customerId       Int?
  customer         Customer?    @relation(fields: [customerId], references: [id])
  supplierId       Int?
  supplier         Supplier?    @relation(fields: [supplierId], references: [id])
  subtotal         Decimal      @default(0)
  discount         Decimal      @default(0)
  taxableAmount    Decimal      @default(0)
  vatRate          Decimal      @default(15)
  vatAmount        Decimal      @default(0)
  withholdingTax   Decimal      @default(0)
  total            Decimal      @default(0)
  paidAmount       Decimal      @default(0)
  outstanding      Decimal      @default(0)
  status           InvoiceStatus @default(DRAFT)
  paymentStatus    String       @default("PENDING")
  projectId        Int?
  project          Project?     @relation(fields: [projectId], references: [id])
  notes            String?
  internalNotes    String?
  zatcaUuid        String?
  zatcaHash        String?
  zatcaQr          String?
  isZatcaCompliant Boolean      @default(false)
  createdById      Int?
  createdBy        User?        @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  journalEntryId   Int?
  journalEntry     JournalEntry? @relation("InvoiceJournalEntry", fields: [journalEntryId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  lines    InvoiceLine[]
  payments PaymentAllocation[]

  @@index([date, status])
  @@index([createdAt])
}

model InvoiceLine {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineNumber  Int
  itemId      Int?
  description String
  quantity    Decimal  @default(1)
  unitPrice   Decimal
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(15)
  taxAmount   Decimal  @default(0)
  total       Decimal
  accountId   Int?
  createdAt   DateTime @default(now())

  @@unique([invoiceId, lineNumber])
}

model BankAccount {
  id             Int      @id @default(autoincrement())
  name           String
  accountNumber  String   @unique
  iban           String?
  bankName       String
  branchId       Int?
  branch         Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  currency       String   @default("KWD")
  accountType    String   @default("Current")
  openingBalance Decimal  @default(0)
  currentBalance Decimal  @default(0)
  glAccountId    Int?
  glAccount      Account? @relation("BankGLAccount", fields: [glAccountId], references: [id])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions BankTransaction[]
  payments     Payment[]

  @@index([branchId, isActive])
}

model BankTransaction {
  id            Int      @id @default(autoincrement())
  bankId        Int
  bank          BankAccount @relation(fields: [bankId], references: [id], onDelete: Cascade)
  date          DateTime
  valueDate     DateTime?
  reference     String?
  description   String
  debit         Decimal  @default(0)
  credit        Decimal  @default(0)
  balance       Decimal?
  type          String?
  counterparty  String?
  isReconciled  Boolean  @default(false)
  reconciledAt  DateTime?
  journalEntryId Int?
  journalEntry  JournalEntry? @relation("BankTxnJournalEntry", fields: [journalEntryId], references: [id])
  createdAt     DateTime @default(now())

  @@index([date])
}

model Payment {
  id            Int          @id @default(autoincrement())
  number        String       @unique
  date          DateTime
  branchId      Int?
  branch        Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  type          PaymentType
  method        PaymentMethod
  amount        Decimal
  currency      String       @default("KWD")
  bankId        Int?
  bank          BankAccount? @relation(fields: [bankId], references: [id])
  customerId    Int?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  supplierId    Int?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  checkNumber   String?
  checkDate     DateTime?
  checkBank     String?
  status        PaymentStatus @default(PENDING)
  description   String?
  notes         String?
  journalEntryId Int?
  journalEntry   JournalEntry? @relation("PaymentJournalEntry", fields: [journalEntryId], references: [id])
  createdById   Int?
  createdBy     User?        @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  allocations PaymentAllocation[]

  @@index([date, status])
  @@index([createdAt])
  @@index([branchId, date])
}

model PaymentAllocation {
  id        Int      @id @default(autoincrement())
  paymentId Int
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal
  createdAt DateTime @default(now())

  @@unique([paymentId, invoiceId])
}

model AssetCategory {
  id                 Int      @id @default(autoincrement())
  code               String   @unique
  nameAr             String
  nameEn             String?
  depreciationMethod String   @default("StraightLine")
  usefulLifeMonths   Int
  salvagePercent     Decimal  @default(0)
  glAssetId          Int?
  glAccumulatedId    Int?
  glExpenseId        Int?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  assets FixedAsset[]
}

model FixedAsset {
  id                     Int        @id @default(autoincrement())
  code                   String     @unique
  nameAr                 String
  nameEn                 String?
  categoryId             Int
  category               AssetCategory @relation(fields: [categoryId], references: [id])
  serialNumber           String?
  model                  String?
  manufacturer           String?
  purchaseDate           DateTime?
  purchaseCost           Decimal
  supplierId             Int?
  usefulLifeMonths       Int?
  depreciationMethod     String?
  salvageValue           Decimal    @default(0)
