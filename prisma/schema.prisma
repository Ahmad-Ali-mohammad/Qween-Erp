}

model CriticalPathSnapshot {
  id                Int          @id @default(autoincrement())
  planId            Int
  plan              SchedulePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  snapshotDate      DateTime     @default(now())
  title             String
  criticalTasksCount Int         @default(0)
  delayedTasksCount Int          @default(0)
  totalTasksCount   Int          @default(0)
  summary           Json         @default("{}")
  status            String       @default("SNAPSHOT")
  createdById       Int?
  updatedById       Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([planId, snapshotDate])
}

model ResourceAssignment {
  id               Int                     @id @default(autoincrement())
  planId           Int
  plan             SchedulePlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  taskId           Int?
  task             ScheduleTask?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  resourceType     String
  resourceRefId    Int
  quantity         Decimal                 @default(1)
  allocationPercent Decimal                @default(100)
  status           String                  @default("ALLOCATED")
  approvalStatus   ApprovalLifecycleStatus @default(DRAFT)
  postingStatus    PostingLifecycleStatus  @default(NOT_APPLICABLE)
  attachmentsCount Int                     @default(0)
  createdById      Int?
  updatedById      Int?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([planId, resourceType])
  @@index([taskId])
}

model Attendance {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  hoursWorked Decimal  @default(0)
  status      String   @default("PRESENT")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([branchId, date])
}

model Timesheet {
  id               Int            @id @default(autoincrement())
  employeeId       Int
  employee         Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId        Int
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId         Int?
  branch           Branch?        @relation(fields: [branchId], references: [id])
  projectExpenseId Int?
  projectExpense   ProjectExpense? @relation(fields: [projectExpenseId], references: [id])
  date             DateTime
  hours            Decimal        @default(0)
  hourlyCost       Decimal        @default(0)
  amount           Decimal        @default(0)
  description      String?
  status           String         @default("DRAFT")
  approvedBy       Int?
  approvedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([branchId, date])
  @@index([employeeId, date])
  @@index([projectId, date])
}

model UserBranchAccess {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([branchId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int?
  title       String
  message     String
  type        String   @default("INFO")
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
}

model UserTask {
  id          Int      @id @default(autoincrement())
  userId      Int?
  title       String
  description String?
  dueDate     DateTime?
  priority    String   @default("MEDIUM")
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BackupJob {
  id             Int      @id @default(autoincrement())
  action         String   @default("BACKUP")
  status         String   @default("QUEUED")
  fileName       String?
  fileSize       Decimal?
  storagePath    String?
  isScheduled    Boolean  @default(false)
  scheduleExpr   String?
  sourceBackupId Int?
  requestedBy    Int?
  requestedAt    DateTime @default(now())
  completedAt    DateTime?
  notes          String?
}

model IntegrationSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  provider    String?
  isEnabled   Boolean  @default(false)
  settings    Json?
  lastSyncAt  DateTime?
  status      String?
  updatedAt   DateTime @updatedAt
}

model Currency {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  nameAr     String
  symbol     String?
  isBase     Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  currencyCode String
  rateDate     DateTime
  rate         Decimal
  source       String?
  createdAt    DateTime @default(now())

  @@unique([currencyCode, rateDate])
}

model ScheduledReport {
  id          Int      @id @default(autoincrement())
  name        String
  reportType  String
  schedule    String
  format      String   @default("PDF")
  recipients  Json?
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SavedReport {
  id          Int      @id @default(autoincrement())
  name        String
  reportType  String
  definition  Json?
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserMfaSetting {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  isEnabled       Boolean  @default(false)
  method          String?
  secret          String?
  backupCodes     Json?
  verifiedAt      DateTime?
  updatedAt       DateTime @updatedAt
}

model SecurityPolicy {
  id                     Int      @id @default(1)
  passwordMinLength      Int      @default(8)
  passwordRequireComplex Boolean  @default(true)
  passwordExpiryDays     Int      @default(90)
  lockoutAttempts        Int      @default(5)
  lockoutMinutes         Int      @default(30)
  sessionTimeoutMinutes  Int      @default(30)
  singleSessionOnly      Boolean  @default(false)
  auditReadActions       Boolean  @default(false)
  auditRetentionDays     Int      @default(180)
  updatedAt              DateTime @updatedAt
}
