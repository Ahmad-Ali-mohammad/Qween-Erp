  updatedAt   DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([branchId, date])
}

model Timesheet {
  id              Int            @id @default(autoincrement())
  employeeId      Int
  employee        Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId       Int
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId        Int?
  branch          Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  projectExpenseId Int?
  projectExpense  ProjectExpense? @relation(fields: [projectExpenseId], references: [id], onDelete: SetNull)
  date            DateTime
  hours           Decimal        @default(0)
  hourlyCost      Decimal        @default(0)
  amount          Decimal        @default(0)
  description     String?
  status          String         @default("DRAFT")
  approvedBy      Int?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([employeeId, date])
  @@index([projectId, date])
  @@index([branchId, date])
}

model EquipmentAllocation {
  id              Int          @id @default(autoincrement())
  assetId         Int
  asset           FixedAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  projectId       Int?
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  branchId        Int?
  branch          Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  projectExpenseId Int?
  projectExpense  ProjectExpense? @relation(fields: [projectExpenseId], references: [id], onDelete: SetNull)
  startDate       DateTime
  endDate         DateTime?
  dailyRate       Decimal      @default(0)
  hourlyRate      Decimal      @default(0)
  hoursUsed       Decimal      @default(0)
  fuelCost        Decimal      @default(0)
  chargeAmount    Decimal      @default(0)
  operatorId      Int?
  status          String       @default("ACTIVE")
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([assetId, status])
  @@index([projectId, status])
  @@index([branchId, startDate])
}

model MaintenanceLog {
  id              Int          @id @default(autoincrement())
  assetId         Int
  asset           FixedAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  projectId       Int?
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  branchId        Int?
  branch          Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplierId      Int?
  supplier        Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  projectExpenseId Int?
  projectExpense  ProjectExpense? @relation(fields: [projectExpenseId], references: [id], onDelete: SetNull)
  serviceDate     DateTime
  completedAt     DateTime?
  type            String
  status          String       @default("OPEN")
  cost            Decimal      @default(0)
  description     String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  siteEquipmentIssues SiteEquipmentIssue[]

  @@index([assetId, status])
  @@index([projectId, status])
  @@index([branchId, serviceDate])
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  type        String
  startDate   DateTime
  endDate     DateTime
  daysCount   Int
  status      String   @default("PENDING")
  reason      String?
  approvedBy  Int?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PayrollRun {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  year        Int
  month       Int
  status      String   @default("DRAFT")
  grossTotal  Decimal  @default(0)
  deductionTotal Decimal @default(0)
  netTotal    Decimal  @default(0)
  runDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines       PayrollLine[]

  @@index([branchId, year, month])
}

model PayrollLine {
  id            Int      @id @default(autoincrement())
  payrollRunId  Int
  payrollRun    PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId    Int
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId      Int?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  basicSalary   Decimal  @default(0)
  allowances    Decimal  @default(0)
  overtime      Decimal  @default(0)
  deductions    Decimal  @default(0)
  netSalary     Decimal  @default(0)

  @@index([payrollRunId])
  @@index([employeeId])
  @@index([branchId])
}

model Contract {
  id          Int      @id @default(autoincrement())
  number      String   @unique
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  title       String
  partyType   String
  partyId     Int?
  type        String?
  startDate   DateTime
  endDate     DateTime?
  value       Decimal  @default(0)
  status      String   @default("DRAFT")
  terms       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
  journalLines JournalLine[]

  @@index([branchId, status])
}

model ContractMilestone {
  id          Int      @id @default(autoincrement())
  contractId  Int
  title       String
  dueDate     DateTime?
  amount      Decimal  @default(0)
  status      String   @default("PENDING")
  notes       String?
}

model NumberSequence {
  id             Int                 @id @default(autoincrement())
  scopeKey       String              @unique
  documentType   String
  branchId       Int?
  branch         Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  resetPolicy    SequenceResetPolicy @default(MONTHLY)
  sequenceYear   Int?
  sequenceMonth  Int?
  prefix         String?
  width          Int                 @default(5)
  currentValue   Int                 @default(0)
  lastGeneratedAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([documentType, branchId])
}

model Attachment {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  fileName    String
  storageKey  String   @unique
  mimeType    String?
  sizeBytes   Int?
  metadata    Json?
  createdBy   Int?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}

model CustomField {
  id           Int      @id @default(autoincrement())
  entityType   String
  key          String
  labelAr      String
  labelEn      String?
  fieldType    String
  isRequired   Boolean  @default(false)
  isVisible    Boolean  @default(true)
  defaultValue Json?
  settings     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  values       CustomFieldValue[]

  @@unique([entityType, key])
}

model CustomFieldValue {
  id            Int      @id @default(autoincrement())
  customFieldId Int
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  entityType    String
  entityId      Int
  value         Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customFieldId, entityType, entityId])
  @@index([entityType, entityId])
}

model PrintJob {
  id           Int      @id @default(autoincrement())
  jobKey       String   @unique
  entityType   String
  recordId     Int?
  templateId   Int?
  format       String
  mode         String   @default("INLINE")
  status       String   @default("PENDING")
  requestedBy  Int?
  requester    User?    @relation(fields: [requestedBy], references: [id], onDelete: SetNull)
  attachmentId Int?
  fileName     String?
  errorMessage String?
  payload      Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, recordId])
  @@index([status, createdAt])
}

model DocumentTemplate {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  entityType  String
  nameAr      String
  nameEn      String?
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  format      String   @default("HTML")
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  content     String
  sampleData  Json?
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType, isActive])
  @@index([branchId, entityType])
}

model WorkflowInstance {
  id           Int                    @id @default(autoincrement())
  workflowKey  String
  entityType   String
  entityId     Int
  status       WorkflowInstanceStatus @default(DRAFT)
  currentStep  String?
  payload      Json?
  startedBy    Int?
  startedAt    DateTime               @default(now())
  completedAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  actions      WorkflowAction[]

  @@index([entityType, entityId])
  @@index([workflowKey, status])
}

model WorkflowAction {
  id                 Int      @id @default(autoincrement())
  workflowInstanceId Int
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  actionKey          String
  actorId            Int?
  actionStatus       String   @default("PENDING")
  notes              String?
  payload            Json?
  createdAt          DateTime @default(now())

  @@index([workflowInstanceId, createdAt])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int?
  title       String
  message     String
  type        String   @default("INFO")
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
}

model UserTask {
  id          Int      @id @default(autoincrement())
  userId      Int?
  title       String
  description String?
  dueDate     DateTime?
  priority    String   @default("MEDIUM")
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BackupJob {
  id             Int      @id @default(autoincrement())
  action         String   @default("BACKUP")
  status         String   @default("QUEUED")
  fileName       String?
  fileSize       Decimal?
  storagePath    String?
  isScheduled    Boolean  @default(false)
  scheduleExpr   String?
  sourceBackupId Int?
  requestedBy    Int?
  requestedAt    DateTime @default(now())
  completedAt    DateTime?
  notes          String?
}

model IntegrationSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  provider    String?
  isEnabled   Boolean  @default(false)
  settings    Json?
  lastSyncAt  DateTime?
  status      String?
  updatedAt   DateTime @updatedAt
}

model Currency {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  nameAr     String
  symbol     String?
  isBase     Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  currencyCode String
  rateDate     DateTime
  rate         Decimal
  source       String?
  createdAt    DateTime @default(now())

  @@unique([currencyCode, rateDate])
}

model ScheduledReport {
  id          Int      @id @default(autoincrement())
  name        String
  reportType  String
  schedule    String
  format      String   @default("PDF")
  recipients  Json?
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SavedReport {
  id          Int      @id @default(autoincrement())
  name        String
  reportType  String
  definition  Json?
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserMfaSetting {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  isEnabled       Boolean  @default(false)
  method          String?
  secret          String?
  backupCodes     Json?
  verifiedAt      DateTime?
  updatedAt       DateTime @updatedAt
}

model SecurityPolicy {
  id                     Int      @id @default(1)
  passwordMinLength      Int      @default(8)
  passwordRequireComplex Boolean  @default(true)
  passwordExpiryDays     Int      @default(90)
  lockoutAttempts        Int      @default(5)
  lockoutMinutes         Int      @default(30)
  sessionTimeoutMinutes  Int      @default(30)
  singleSessionOnly      Boolean  @default(false)
  auditReadActions       Boolean  @default(false)
  auditRetentionDays     Int      @default(180)
  updatedAt              DateTime @updatedAt
}
